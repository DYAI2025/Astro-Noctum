  "api_endpoints": {
    "base_url": "/api/v1/quizzme",
    "endpoints": {
      "list_modules": {
        "method": "GET",
        "path": "/modules",
        "description": "Liste aller verfügbaren Quiz-Module"
      },
      "get_module": {
        "method": "GET",
        "path": "/modules/{moduleId}",
        "description": "Details eines spezifischen Moduls"
      },
      "get_questions": {
        "method": "GET",
        "path": "/modules/{moduleId}/questions",
        "description": "Fragen eines Moduls abrufen"
      },
      "submit_answers": {
        "method": "POST",
        "path": "/modules/{moduleId}/submit",
        "description": "Antworten einreichen und Ergebnis berechnen",
        "request_body": {
          "answers": [
            { "questionId": "string", "optionId": "string" }
          ]
        },
        "response": {
          "contributionEvent": "ContributionEvent",
          "profile": "Profile",
          "shareCard": "ShareCard"
        }
      },
      "get_profile": {
        "method": "GET",
        "path": "/modules/{moduleId}/profiles/{profileId}",
        "description": "Profil-Details abrufen"
      },
      "aggregate_character_sheet": {
        "method": "POST",
        "path": "/character-sheet/aggregate",
        "description": "Character Sheet aus allen ContributionEvents aggregieren",
        "request_body": {
          "eventIds": ["string"]
        }
      },
      "cluster_progress": {
        "method": "GET",
        "path": "/clusters/{clusterId}/progress",
        "description": "Fortschritt in einem Quiz-Cluster"
      }
    }
  },

