    "scoring": {
      "normalization": {
        "min": 1,
        "max": 100,
        "bands": [
          { "range": [1, 20], "label": "low", "emoji": "❄️" },
          { "range": [21, 40], "label": "midlow", "emoji": "🌿" },
          { "range": [41, 60], "label": "mid", "emoji": "🌤️" },
          { "range": [61, 80], "label": "midhigh", "emoji": "🔥" },
          { "range": [81, 100], "label": "high", "emoji": "⚡" }
        ]
      },
      "confidence_formula": "clamp(1 - (stddev / maxStddev), 0, 1)"
    },
    "viral_mechanics": {
      "share_platforms": ["instagram", "tiktok", "twitter", "whatsapp"],
      "hashtags_global": ["QuizzMe", "Persönlichkeitstest", "WerBistDu"],
      "cta_templates": {
        "share": "Teile dein Ergebnis!",
        "tag_ally": "Tagge deinen {ally_type}!",
        "tag_nemesis": "Wer ist dein {nemesis_type}?",
